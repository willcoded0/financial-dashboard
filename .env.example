# Copy to .env and fill in values before deploying

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-string

# Your hosted Ollama instance
OLLAMA_HOST=https://ai.batmap.win
OLLAMA_MODEL=qwen2.5:3b

# Optional: set HOST/PORT if not using docker-compose
# HOST=0.0.0.0
# PORT=5000
